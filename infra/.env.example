# =============================================================================
# RAG System Environment Variables
# Copy this file to infra/.env for Docker Compose, or to .env at the project
# root for local service execution.
# =============================================================================

# API_HOST: Interface the API service binds to when launched directly.
API_HOST=0.0.0.0

# API_PORT: Host port exposed for the API service.
API_PORT=8000

# NOTE: Do NOT set a global/shared PORT variable here. Each service reads PORT and
# would override its own listen port (e.g. ingestion -> 8000), breaking inter-service
# calls. PORT is set only on the api service in docker-compose.yml. On Dokploy, never
# add PORT as a project/global environment variable; scope it to the api service only.

# OPENAI_API_KEY: OpenAI API key used for chat completions and embeddings.
OPENAI_API_KEY=

# LLM_MODEL: Chat model used by the API for answer generation.
LLM_MODEL=gpt-4o-mini

# LLM_MAX_TOKENS: Maximum tokens the LLM may generate for one response.
LLM_MAX_TOKENS=1000

# LLM_TEMPERATURE: Sampling temperature for answer generation.
LLM_TEMPERATURE=0.0

# EMBEDDING_MODEL: Embedding model used for ingestion and query embeddings.
EMBEDDING_MODEL=text-embedding-3-small

# EMBEDDING_DIMENSIONS: Vector size produced by EMBEDDING_MODEL.
EMBEDDING_DIMENSIONS=1536

# QDRANT_URL: URL the services use to reach Qdrant.
QDRANT_URL=http://qdrant:6333

# QDRANT_API_KEY: Optional API key for secured Qdrant deployments.
QDRANT_API_KEY=

# QDRANT_COLLECTION: Qdrant collection that stores document chunks.
QDRANT_COLLECTION=documents

# QDRANT_PORT: Host port exposed for the local Qdrant container.
QDRANT_PORT=6333

# RETRIEVAL_TOP_K: Final number of chunks returned to the LLM context.
RETRIEVAL_TOP_K=5

# RETRIEVAL_CANDIDATE_K: Number of retrieval candidates collected before reranking.
RETRIEVAL_CANDIDATE_K=20

# HYBRID_ALPHA: Hybrid retrieval weight, where 0 is BM25 only and 1 is dense only.
HYBRID_ALPHA=0.5

# MAX_CONTEXT_TOKENS: Maximum retrieved context tokens sent to the LLM.
MAX_CONTEXT_TOKENS=6000

# INGESTION_URL: Internal URL for the API to call the ingestion service.
INGESTION_URL=http://ingestion:8002

# RERANKER_URL: Internal URL for the API to call the reranker sidecar.
RERANKER_URL=http://reranker:8001

# RERANKER_ENABLED: Whether the API reranks retrieval candidates before generation.
RERANKER_ENABLED=true

# RERANKER_HOST: Interface the reranker service binds to when launched directly.
RERANKER_HOST=0.0.0.0

# RERANKER_PORT: Host port exposed for the reranker sidecar.
RERANKER_PORT=8001

# RERANKER_MODEL: Cross-encoder model loaded by the reranker sidecar.
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# REDIS_URL: Redis URL used by the API semantic cache.
REDIS_URL=redis://redis:6379

# CACHE_SIMILARITY_THRESHOLD: Minimum similarity score required for a cache hit.
CACHE_SIMILARITY_THRESHOLD=0.95

# CACHE_TTL_SECONDS: Semantic cache entry time-to-live in seconds.
CACHE_TTL_SECONDS=3600

# INGESTION_PARENT_CHUNK_SIZE: Target size for parent document chunks.
INGESTION_PARENT_CHUNK_SIZE=1500

# INGESTION_CHILD_CHUNK_SIZE: Target size for child chunks used in retrieval.
INGESTION_CHILD_CHUNK_SIZE=300

# INGESTION_CHUNK_OVERLAP: Overlap retained between adjacent document chunks.
INGESTION_CHUNK_OVERLAP=50

# INGESTION_BATCH_SIZE: Number of chunks embedded/upserted per ingestion batch.
INGESTION_BATCH_SIZE=100

# DEFAULT_TENANT_ID: Fallback tenant id for single-tenant or unspecified requests.
DEFAULT_TENANT_ID=default

# LOG_LEVEL: Application log level for all services.
LOG_LEVEL=INFO

# ENABLE_TRACING: Whether tracing instrumentation should be enabled.
ENABLE_TRACING=true
